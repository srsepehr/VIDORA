# Vidora worker configuration. Copy to the worker host's secret store — NEVER
# commit real values and NEVER expose these to the browser/Vite build.

# --- Supabase (service role: full DB/storage access, server-side only) ------
SUPABASE_URL=https://kvqrkphoyuoblfonjcvo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=              # secret — from Supabase project settings
UPLOAD_BUCKET=vidora-video-uploads

# --- Queue / leasing --------------------------------------------------------
WORKER_ID=                              # optional; defaults to host-pid
LEASE_SECONDS=120
HEARTBEAT_SECONDS=20
POLL_INTERVAL_SECONDS=5
REAP_INTERVAL_SECONDS=30

# --- Media limits (private zero-cost phase) ---------------------------------
MAX_SOURCE_BYTES=104857600             # 100 MB
MAX_DURATION_SECONDS=120               # 2 minutes

# --- Speech-to-text (self-hosted faster-whisper; no API key) ----------------
STT_PROVIDER=faster_whisper
STT_MODEL=base                         # smallest practical multilingual; tiny|base|small|medium
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=5
STT_DOWNLOAD_ROOT=/models

# --- Translation ------------------------------------------------------------
# Private zero-cost phase: self-hosted NLLB-200 (no API, no key, no charge).
TRANSLATION_PROVIDER=local_nllb        # local_nllb | openai_compatible
NLLB_MODEL=facebook/nllb-200-distilled-600M
NLLB_TARGET_LANG=pes_Arab              # Western Persian (FLORES-200)
# Public phase only (paid LLM): set TRANSLATION_PROVIDER=openai_compatible and:
TRANSLATION_BASE_URL=                   # e.g. https://api.deepinfra.com/v1/openai
TRANSLATION_MODEL=                      # e.g. Qwen/Qwen2.5-72B-Instruct
TRANSLATION_API_KEY=                    # secret — from the chosen provider
TRANSLATION_BATCH_CHARS=4000
TRANSLATION_MAX_RETRIES=3

# --- Health server ----------------------------------------------------------
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

# --- Ops --------------------------------------------------------------------
WORK_DIR=/tmp/vidora-worker
LOG_TRANSCRIPTS=false                   # keep transcript text out of logs
GIT_COMMIT=                             # injected at deploy for /ready
