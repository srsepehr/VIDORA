# Public browser-safe Supabase values. Vite only exposes variables prefixed with VITE_.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Public app URL used for auth redirects. For GitHub Pages, use the deployed site URL.
VITE_APP_URL=http://localhost:5173

# Public Supabase Edge gateway for authenticated grounded video chat.
VITE_VIDEO_CHAT_URL=https://your-project-ref.supabase.co/functions/v1/video-chat

# Server-only values. Do not expose these in browser code or GitHub Pages env.
# Use them only from Supabase Edge Functions, server workers, or a future backend.
SUPABASE_SERVICE_ROLE_KEY=never-commit-real-service-role-key

# Later phases.
VIDEO_WORKER_QUEUE_URL=
VIDEO_WORKER_SIGNING_SECRET=
AI_TRANSCRIPTION_PROVIDER_KEY=
AI_TRANSLATION_PROVIDER_KEY=
